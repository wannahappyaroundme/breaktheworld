{
  "name": "breaktheworld",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "세상 부수기 — 모바일 전용 스트레스 해소 파괴 애니메이션",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint:copy": "node --test scripts/copy-lint.test.mjs && node scripts/copy-lint.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify:player-auth": "node --experimental-websocket scripts/verify-player-auth.mjs",
    "verify:player-sync": "node --experimental-websocket scripts/verify-player-sync.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.109.0",
    "roughjs": "^4.6.6"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "supabase": "^2.109.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
